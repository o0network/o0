{
  "manifest_version": 3,
  "name": "Chrome Launcher Extension",
  "version": "1.0",
  "description": "Launches Chrome in headless mode via native messaging",
  "permissions": ["nativeMessaging", "windows"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_icon": {
      "16": "icon16.png",
      "32": "icon32.png",
      "48": "icon48.png",
      "128": "icon128.png"
    },
    "default_title": "Toggle Auto-Open (15s)"
  },
  "icons": {
    "16": "icon16.png",
    "32": "icon32.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "externally_connectable": {
    "matches": ["*://localhost/*"]
  }
}
